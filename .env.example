# Скопируйте в .env в том же каталоге, что и api_trained.py:
#   Windows:  copy .env.example .env
#   Linux:    cp .env.example .env
# Затем подставьте свои значения. Строки с # в начале — комментарии.

# ---------- API (uvicorn при py -3 api_trained.py) ----------
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# Макс. размер загрузки одного файла (МБ)
API_MAX_UPLOAD_MB=32

# Режим полей: merge | neural_trained | regex_only
# merge — seq2seq/vLLM + regex; neural_trained — только модель полей; regex_only — без нейросети полей
API_FIELDS_MODE=merge

# Пути к чекпоинтам (относительно каталога запуска или абсолютные)
DOC_CLASSIFIER_CKPT=checkpoints/doc_classifier
INVOICE_EXTRACT_CKPT=checkpoints/invoice_extract

# ---------- vLLM (извлечение реквизитов; OpenAI-совместимый API) ----------
# Если заданы ОБА VLLM_OPENAI_BASE и VLLM_MODEL — извлечение идёт в vLLM.
# Чтобы принудительно локальный seq2seq из INVOICE_EXTRACT_CKPT: EXTRACT_BACKEND=local
# EXTRACT_BACKEND=vllm — явно только vLLM (удобно вместе с URL/моделью)
EXTRACT_BACKEND=
VLLM_OPENAI_BASE=http://127.0.0.1:8000/v1
VLLM_MODEL=
# Опционально: Bearer для vLLM, если включена авторизация
VLLM_API_KEY=
VLLM_TIMEOUT_SEC=120

# Параметры генерации (локальный seq2seq и vLLM для длины ответа/контекста)
EXTRACT_MAX_INPUT_CHARS=6000
EXTRACT_MAX_NEW_TOKENS=320
EXTRACT_NUM_BEAMS=1

# ---------- Yandex Vision OCR (PDF/картинки в режиме auto/ocr) ----------
# 1 — включить OCR; 0 или пусто — выключить
OCR_YANDEX_ENABLED=0
OCR_YANDEX_FOLDER_ID=
# Либо IAM-токен, либо OAuth-токен сервисного аккаунта (см. документацию Yandex Cloud)
OCR_YANDEX_IAM_TOKEN=
OCR_YANDEX_OAUTH_TOKEN=
OCR_YANDEX_LANGS=ru,en
OCR_YANDEX_DPI=200
OCR_YANDEX_MAX_PAGES=10
